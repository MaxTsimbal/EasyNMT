# Скопіюй цей файл як .env. Справжній ключ не завантажуй у GitHub.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TUTOR_FAST_MODEL=gpt-4o-mini
OPENAI_TUTOR_MODEL=gpt-4o-mini
OPENAI_TUTOR_REASONING_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_GRADING_MODEL=gpt-4o-mini
OPENAI_MAX_OUTPUT_TOKENS=900
OPENAI_CURRICULUM_MAX_OUTPUT_TOKENS=5000
OPENAI_LESSON_MAX_OUTPUT_TOKENS=6500
OPENAI_WRITTEN_GRADING_MAX_OUTPUT_TOKENS=2600
OPENAI_WRITTEN_GRADING_ENABLED=1
OPENAI_TIMEOUT_SECONDS=45
OPENAI_MAX_RETRIES=1
OPENAI_STORE_RESPONSES=0
OPENAI_DAILY_LIMIT=40
OPENAI_MAX_QUESTION_CHARS=1500
AI_MAX_ATTACHMENTS=3
AI_DAILY_UPLOAD_LIMIT=20
AI_MAX_ATTACHMENT_BYTES=5242880

# Required in production. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
FLASK_DEBUG=0
GOOGLE_SITE_VERIFICATION=

# Google Sign-In
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Локально: http://127.0.0.1:5000/auth/google/callback
# Railway: https://YOUR-DOMAIN/auth/google/callback
GOOGLE_REDIRECT_URI=
SESSION_COOKIE_SECURE=0

# Task 4D: final question 12 photo or text grading
OPENAI_FINAL_SOLUTION_ENABLED=1
OPENAI_FINAL_SOLUTION_MODEL=
OPENAI_FINAL_SOLUTION_MAX_OUTPUT_TOKENS=1800
QUIZ_SOLUTION_PHOTO_MAX_BYTES=6291456
QUIZ_SOLUTION_PHOTO_MAX_DIMENSION=2400

# Task 5: v1.0 Beta readiness, persistent backups, and release gates
EASYNMT_AUTO_BACKUP=1
EASYNMT_BACKUP_INTERVAL_HOURS=24
EASYNMT_BACKUP_MAX_AGE_HOURS=30
EASYNMT_BACKUP_RETENTION=7
EASYNMT_BETA_MIN_FREE_BYTES=20971520
# Railway defaults these two requirements to 1. Keep them explicit for clarity.
EASYNMT_BETA_REQUIRE_PERSISTENT_VOLUME=1
EASYNMT_BETA_REQUIRE_OPENAI=1
EASYNMT_BETA_REQUIRE_BACKUP=1
# Email login remains available when Google OAuth is optional.
EASYNMT_BETA_REQUIRE_GOOGLE_OAUTH=0
# Production should not silently replace an unavailable AI lesson with a local template.
EASYNMT_ALLOW_DETERMINISTIC_LESSON_FALLBACK=0
WEB_CONCURRENCY=1

