# Скопіюй цей файл як .env. Справжній ключ не завантажуй у GitHub.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_MAX_OUTPUT_TOKENS=900
OPENAI_TIMEOUT_SECONDS=45
OPENAI_MAX_RETRIES=1
OPENAI_STORE_RESPONSES=0
OPENAI_DAILY_LIMIT=40
OPENAI_MAX_QUESTION_CHARS=1500
AI_MAX_ATTACHMENTS=3
AI_DAILY_UPLOAD_LIMIT=20
AI_MAX_ATTACHMENT_BYTES=5242880

SECRET_KEY=replace-with-a-long-random-secret
FLASK_DEBUG=1
GOOGLE_SITE_VERIFICATION=

# Google Sign-In
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Локально: http://127.0.0.1:5000/auth/google/callback
# Railway: https://YOUR-DOMAIN/auth/google/callback
GOOGLE_REDIRECT_URI=
SESSION_COOKIE_SECURE=0
