# Скопіюй цей файл як .env і встав свій ключ лише локально.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_OUTPUT_TOKENS=500
OPENAI_DAILY_LIMIT=40
OPENAI_MAX_QUESTION_CHARS=1500
SECRET_KEY=replace-with-a-long-random-secret
FLASK_DEBUG=1
GOOGLE_SITE_VERIFICATION=


# Модель для перевірки фотографій письмових робіт
OPENAI_VISION_MODEL=gpt-4o-mini

# Google Sign-In (створюються в Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Локально: http://127.0.0.1:5000/auth/google/callback
# Railway: https://YOUR-DOMAIN/auth/google/callback
GOOGLE_REDIRECT_URI=
SESSION_COOKIE_SECURE=0
